{
  "name": "sistema-de-vendas-online",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "tsx src/server.ts",
    "client": "cd client && npm run dev",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "migrate:legacy": "tsx src/migrate-legacy-data.ts"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "socket.io": "^4.8.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.8",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.2.1",
    "prisma": "^7.6.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
